{
  "name": "volunteer-helper",
  "version": "1.0.0",
  "private": true,
  "description": "高考志愿填报助手",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter web dev",
    "dev:server": "pnpm --filter server dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter web build",
    "build:server": "pnpm --filter server build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter server prisma migrate dev",
    "db:generate": "pnpm --filter server prisma generate",
    "db:studio": "pnpm --filter server prisma studio",
    "import:data": "cd scripts/import-data && tsx index.ts",
    "db:deploy": "pnpm --filter server prisma migrate deploy",
    "db:push": "pnpm --filter server prisma db push"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prisma": "^7.4.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "dependencies": {
    "@prisma/client": "^7.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/client",
      "@prisma/engines",
      "bcrypt"
    ]
  }
}
