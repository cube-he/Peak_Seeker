# 数据库
DATABASE_URL="postgresql://postgres:password@localhost:5432/volunteer_helper?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Claude API
CLAUDE_API_KEY=your-claude-api-key

# 应用配置
PORT=3001
NODE_ENV=development

# OCR 微服务
OCR_SERVICE_URL=http://127.0.0.1:8100

# 支付配置 (可选)
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
